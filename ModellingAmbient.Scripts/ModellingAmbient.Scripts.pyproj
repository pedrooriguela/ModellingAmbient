    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\python.cat" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\python.exe" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\python3.dll" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\python314.dll" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\python314.zip" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\python314._pth" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\pythonw.exe" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\select.pyd" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\sqlite3.dll" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\unicodedata.pyd" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\vcruntime140.dll" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\vcruntime140_1.dll" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\winsound.pyd" />
