    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\_bz2.pyd" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\_ctypes.pyd" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\_decimal.pyd" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\_elementtree.pyd" />
    <Content Include="PythonRuntime\python-3.14.5-embed-amd64\_hashlib.pyd" />
